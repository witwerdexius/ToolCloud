# ─── Supabase ────────────────────────────────────────────────────────────────
# Werte aus: Supabase Dashboard → Project Settings → API

# Projekt-URL (öffentlich sichtbar, kein Secret)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/Public Key (öffentlich sichtbar, kein Secret)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key – NUR serverseitig! Niemals im Frontend verwenden.
# Benötigt für: Aufruf der Edge Functions (Benachrichtigungs-E-Mails)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
