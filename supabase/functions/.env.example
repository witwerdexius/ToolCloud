# Edge Function Secrets – in Supabase setzen mit:
#   supabase secrets set KEY=value
#
# ODER im Dashboard: Project Settings → Edge Functions → Secrets

# Resend API-Key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Absender-Adresse (Domain muss in Resend verifiziert sein)
# Für lokales Testen: onboarding@resend.dev (kein DNS-Setup nötig)
FROM_EMAIL=ToolCloud <noreply@toolcloud.de>

# App-URL (für Links in E-Mails)
APP_URL=https://toolcloud.de

# Automatisch von Supabase bereitgestellt – NICHT manuell setzen:
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_ANON_KEY
